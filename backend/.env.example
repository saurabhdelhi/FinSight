# FinSight Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://finsight:finsight_pass@localhost:5432/finsight_db

# JWT Auth
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Tally Defaults
TALLY_DEFAULT_HOST=localhost
TALLY_DEFAULT_PORT=9000
TALLY_REQUEST_TIMEOUT=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Report Storage
REPORT_STORAGE_PATH=./reports

# App
APP_NAME=FinSight
APP_VERSION=1.0.0
DEBUG=true
